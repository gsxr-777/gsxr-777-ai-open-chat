msgid "Title is too long. Maximum 100 characters, current: %d"
msgstr "Заголовок слишком длинный. Максимум 100 символов, сейчас: %d"

msgid "Top P"
msgstr "Top P"

msgid "Use a playful and humorous tone while keeping answers accurate."
msgstr "Используйте игривый и юмористический тон, сохраняя точность ответов."

msgid "Use formal, professional language and structured responses."
msgstr "Используйте формальный профессиональный язык и структурированные ответы."

msgid "Use light sarcasm carefully, without insulting the user. Keep answers useful."
msgstr "Используйте легкий сарказм аккуратно, не оскорбляя пользователя. Ответы должны быть полезными."

msgid "Used for header/button/message gradients."
msgstr "Используется для градиентов заголовка, кнопок и сообщений."

msgid "Used in chat messages and input area."
msgstr "Используется в сообщениях чата и поле ввода."

msgid "User Message Text"
msgstr "Текст сообщения пользователя"

msgid "Welcome message is too long. Maximum 500 characters, current: %d"
msgstr "Приветственное сообщение слишком длинное. Максимум 500 символов, сейчас: %d"

msgid "Widget Font Family"
msgstr "Семейство шрифта виджета"

msgid "Yandex Project ID is required (OpenAI-Project header)"
msgstr "Требуется Yandex Project ID (заголовок OpenAI-Project)"

msgid "Your API key (stored encrypted). Leave blank to keep current key."
msgstr "Ваш API ключ (хранится в зашифрованном виде). Оставьте поле пустым, чтобы сохранить текущий ключ."

msgid "Основные"
msgstr "Основные"

