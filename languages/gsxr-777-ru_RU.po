msgstr "Отсутствуют обязательные поля"

msgid "Nucleus sampling threshold (0.0-1.0). Lower values make output more focused."
msgstr "Порог nucleus sampling (0.0-1.0). Меньшие значения делают ответы более сфокусированными."

msgid "Optional for most providers. Required for Yandex Responses API as OpenAI-Project header value (example: b1gad9eo3bbmgfl7od3h)."
msgstr "Необязательно для большинства провайдеров. Для Yandex Responses API обязательно как значение заголовка OpenAI-Project (пример: b1gad9eo3bbmgfl7od3h)."

msgid "Pragmatic"
msgstr "Прагматичный"

msgid "Presence Penalty"
msgstr "Штраф за новизну"

msgid "Project / Folder ID"
msgstr "ID проекта / папки"

msgid "Reduces repetitive words or phrases (-2.0 to 2.0)."
msgstr "Снижает повторяемость слов и фраз (-2.0 до 2.0)."

msgid "Respond as a domain expert with concise technical precision."
msgstr "Отвечайте как профильный эксперт с краткой технической точностью."

msgid "Response generation timeout. Please try again."
msgstr "Время генерации ответа истекло. Попробуйте еще раз."

msgid "Response incomplete"
msgstr "Ответ неполный"

msgid "Response incomplete: %s"
msgstr "Ответ неполный: %s"

msgid "Response is still being generated. Please try again in a few seconds."
msgstr "Ответ все еще генерируется. Попробуйте снова через несколько секунд."

msgid "Sarcastic"
msgstr "Саркастичный"

msgid "Secondary Gradient Color"
msgstr "Второй цвет градиента"

msgid "Show empathy, acknowledge user context, and respond with care."
